// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  username String
  avatar   String?
  role     String

  dailyLogs          DailyLog[]
  technicalApprovals TechnicalApproval[]
  projects           Project[]
}

model Project {
  id                String @id @default(cuid())
  code              String @unique
  name              String
  location          String
  surface_sqft      Float
  structure_type    String
  intervention_type String
  userId            String
  user              User   @relation(fields: [userId], references: [id])

  phases           Phase[]
  projectSnapshots ProjectSnapshot[]
}

model Phase {
  id            String   @id @default(cuid())
  name          String
  planned_start DateTime
  planned_end   DateTime
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])

  tasks              Task[]
  dailyLogs          DailyLog[]
  technicalApprovals TechnicalApproval[]
}

model Trade {
  id          String  @id @default(cuid())
  name        String
  description String?

  tasks Task[]
}

model Task {
  id          String  @id @default(cuid())
  name        String
  description String?
  phaseId     String
  tradeId     String
  phase       Phase   @relation(fields: [phaseId], references: [id])
  trade       Trade   @relation(fields: [tradeId], references: [id])

  executedTasks ExecutedTask[]
}

model ExecutedTask {
  id         String   @id @default(cuid())
  taskId     String
  dailyLogId String
  task       Task     @relation(fields: [taskId], references: [id])
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id])

  materialUsages MaterialUsage[]
}

model DailyLog {
  id                    String   @id @default(cuid())
  notes                 String?
  log_date              DateTime @default(now())
  completion_percentage Float?
  schedule_deviation    Float?
  userId                String
  phaseId               String
  user                  User     @relation(fields: [userId], references: [id])
  phase                 Phase    @relation(fields: [phaseId], references: [id])

  executedTasks   ExecutedTask[]
  incidents       Incident[]
  safetyMeasures  SafetyMeasure[]
  workerCoverages WorkerCoverage[]
}

model Incident {
  id            String   @id @default(cuid())
  description   String
  incident_date DateTime @default(now())
  dailyLogId    String
  dailyLog      DailyLog @relation(fields: [dailyLogId], references: [id])
}

model SafetyMeasure {
  id          String   @id @default(cuid())
  description String
  dailyLogId  String
  dailyLog    DailyLog @relation(fields: [dailyLogId], references: [id])
}

model WorkerCoverage {
  id               String   @id @default(cuid())
  coverage_status  String
  coverage_type    String
  policy_reference String
  dailyLogId       String
  dailyLog         DailyLog @relation(fields: [dailyLogId], references: [id])
}

model TechnicalApproval {
  id            String   @id @default(cuid())
  status        String
  comments      String?
  approval_date DateTime @default(now())
  userId        String
  phaseId       String
  user          User     @relation(fields: [userId], references: [id])
  phase         Phase    @relation(fields: [phaseId], references: [id])
}

model ProjectSnapshot {
  id            String     @id @default(cuid())
  snapshot_date DateTime   @default(now())
  period_label  String
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id])
  aiReports     AIReport[]
}

model AIReport {
  id                String          @id @default(cuid())
  generated_at      DateTime        @default(now())
  summary           String?
  projectSnapshotId String
  projectSnapshot   ProjectSnapshot @relation(fields: [projectSnapshotId], references: [id])
}

model Material {
  id          String  @id @default(cuid())
  name        String
  unit        String
  description String?

  materialUsages MaterialUsage[]
}

model MaterialUsage {
  id             String       @id @default(cuid())
  quantity       Float
  executedTaskId String
  materialId     String
  executedTask   ExecutedTask @relation(fields: [executedTaskId], references: [id])
  material       Material     @relation(fields: [materialId], references: [id])
}
