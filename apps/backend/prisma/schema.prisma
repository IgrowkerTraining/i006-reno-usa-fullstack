generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  password           String
  username           String
  avatar             String?
  role               Role
  trade              String?
  assignedProjects   Project[]           @relation("AssignedProfessional")
  projects           Project[]
  projectTeamMembers ProjectTeamMember[]
}

model ProjectTeamMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])
}

model Project {
  id                     String              @id @default(cuid())
  code                   String              @unique
  name                   String
  category               String
  initial_status         String?
  assignedProfessionalId String?
  trades                 String[]
  project_plan_photo     String?
  location               String
  surface_sqft           Float?
  structure_type         String?
  intervention_type      String?
  userId                 String
  phases                 Phase[]
  assignedProfessional   User?               @relation("AssignedProfessional", fields: [assignedProfessionalId], references: [id])
  user                   User                @relation(fields: [userId], references: [id])
  projectTeam            ProjectTeamMember[]
}

model Phase {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  planned_start      DateTime
  planned_end        DateTime
  projectId          String
  status             String              @default("pending")
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks              Task[]
}

model Trade {
  id          String  @id @default(cuid())
  name        String
  description String?
  tasks       Task[]
}

model Task {
  id            String          @id @default(cuid())
  name          String
  description   String?
  status        String          @default("pending")
  category      String          @default("CORRECTION")
  order         Int             @default(0)
  is_incidence  Boolean         @default(false)
  completedAt   DateTime?
  completedBy   String?
  phaseId       String
  tradeId       String?
  phase         Phase           @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  trade         Trade?          @relation(fields: [tradeId], references: [id])
}

enum Role {
  user
  professional
}
