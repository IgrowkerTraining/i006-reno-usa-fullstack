generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PROFESSIONAL
  ADMIN
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  password           String
  username           String
  avatar             String?
  role               Role     @default(USER)
  dailyLogs          DailyLog[]
  projects           Project[]
  technicalApprovals TechnicalApproval[]
}

model Project {
  id                   String     @id @default(cuid())
  code                 String     @unique
  name                 String
  category             String
  initial_status       String?          // opcional
  assigned_professional String?         // opcional
  project_team         String[]         // lista, no opcional
  trades               String[]         // lista, no opcional
  project_plan_photo   String?          // opcional
  location             String
  surface_sqft         Float?
  structure_type       String?
  intervention_type    String?
  userId               String
  phases               Phase[]
  user                 User             @relation(fields: [userId], references: [id])
  projectSnapshots     ProjectSnapshot[]
}


model Phase {
  id                 String              @id @default(cuid())
  name               String   
  description        String?
  planned_start      DateTime
  planned_end        DateTime
  projectId          String
  dailyLogs          DailyLog[]
  project            Project             @relation(fields: [projectId], references: [id])
  tasks              Task[]
  technicalApprovals TechnicalApproval[]
  status             String              @default("pending")
}

model Trade {
  id          String  @id @default(cuid())
  name        String
  description String?
  tasks       Task[]
}

model Task {
  id            String          @id @default(cuid())
  name          String
  description   String?
  phaseId       String
  tradeId       String
  phase         Phase           @relation(fields: [phaseId], references: [id])
  trade         Trade           @relation(fields: [tradeId], references: [id])
  executedTasks TaskExecution[]
}

model TaskExecution {
  id                 String          @id @default(cuid())
  taskId             String
  dailyLogId         String
  progressPercentage Float?
  notes              String?
  executedAt         DateTime        @default(now())
  materialUsages     MaterialUsage[]
  dailyLog           DailyLog        @relation(fields: [dailyLogId], references: [id])
  task               Task            @relation(fields: [taskId], references: [id])

  @@unique([taskId, dailyLogId])
}

model DailyLog {
  id                    String           @id @default(cuid())
  notes                 String?
  log_date              DateTime         @default(now())
  completion_percentage Float?
  schedule_deviation    Float?
  userId                String
  phaseId               String
  phase                 Phase            @relation(fields: [phaseId], references: [id])
  user                  User             @relation(fields: [userId], references: [id])
  incidents             Incident[]
  safetyMeasures        SafetyMeasure[]
  executedTasks         TaskExecution[]
  workerCoverages       WorkerCoverage[]
}

model Incident {
  id            String   @id @default(cuid())
  description   String
  incident_date DateTime @default(now())
  dailyLogId    String
  dailyLog      DailyLog @relation(fields: [dailyLogId], references: [id])
}

model SafetyMeasure {
  id          String   @id @default(cuid())
  description String
  dailyLogId  String
  dailyLog    DailyLog @relation(fields: [dailyLogId], references: [id])
}

model WorkerCoverage {
  id               String   @id @default(cuid())
  coverage_status  String
  coverage_type    String
  policy_reference String
  dailyLogId       String
  dailyLog         DailyLog @relation(fields: [dailyLogId], references: [id])
}

model TechnicalApproval {
  id            String   @id @default(cuid())
  status        String
  comments      String?
  approval_date DateTime @default(now())
  userId        String
  phaseId       String
  phase         Phase    @relation(fields: [phaseId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
}

model ProjectSnapshot {
  id            String     @id @default(cuid())
  snapshot_date DateTime   @default(now())
  period_label  String
  projectId     String
  aiReports     AIReport[]
  project       Project    @relation(fields: [projectId], references: [id])
}

model AIReport {
  id                String          @id @default(cuid())
  generated_at      DateTime        @default(now())
  summary           String?
  projectSnapshotId String
  projectSnapshot   ProjectSnapshot @relation(fields: [projectSnapshotId], references: [id])
}

model Material {
  id             String          @id @default(cuid())
  name           String
  unit           String
  description    String?
  materialUsages MaterialUsage[]
}

model MaterialUsage {
  id             String        @id @default(cuid())
  quantity       Float
  executedTaskId String
  materialId     String
  executedTask   TaskExecution @relation(fields: [executedTaskId], references: [id])
  material       Material      @relation(fields: [materialId], references: [id])
}

